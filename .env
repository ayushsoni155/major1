# ============================================
# RapidBase BaaS — Shared Environment Config
# ============================================

# ---- PostgreSQL ----
POSTGRES_USER=rapidbase
POSTGRES_PASSWORD=rapidbase_secret_2024
POSTGRES_DB=rapidbase
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://rapidbase:rapidbase_secret_2024@postgres:5432/rapidbase

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- JWT ----
JWT_SECRET=rapidbase-jwt-super-secret-key-change-in-production
JWT_REFRESH_SECRET=rapidbase-jwt-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ---- Service Ports ----
AUTH_SERVICE_PORT=4001
PROJECT_SERVICE_PORT=4002
DATABASE_SERVICE_PORT=4003
ANALYTICS_SERVICE_PORT=4004
API_GATEWAY_PORT=5000
FRONTEND_PORT=3000

# ---- Service URLs (internal Docker network) ----
AUTH_SERVICE_URL=http://auth-service:4001
PROJECT_SERVICE_URL=http://project-service:4002
DATABASE_SERVICE_URL=http://database-service:4003
ANALYTICS_SERVICE_URL=http://analytics-service:4004

# ---- PostgREST ----
PGRST_DB_URI=postgresql://rapidbase:rapidbase_secret_2024@postgres:5432/rapidbase
PGRST_DB_ANON_ROLE=web_anon
PGRST_DB_SCHEMAS=public
PGRST_SERVER_PORT=3001

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:5000/api
