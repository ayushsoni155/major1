# ============================================================
# RapidBase BaaS — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=rapidbase
POSTGRES_PASSWORD=change_me_in_production_32chars
POSTGRES_DB=rapidbase
DATABASE_URL=postgresql://rapidbase:change_me_in_production_32chars@postgres:5432/rapidbase

# ---- Redis ----
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379

# ---- JWT (use long random strings — min 64 chars) ----
JWT_SECRET=change_me_jwt_secret_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_refresh_secret_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Cookie Session ----
COOKIE_SECRET=change_me_cookie_secret_min_32_chars_xxxxxxxxxxxxxxxxxxxx

# ---- SMTP (for OTP emails) ----
# For local/dev testing: leave blank to use Ethereal (fake SMTP, logs to console)
# For production: fill with real SMTP credentials
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RapidBase <noreply@rapidbase.dev>"

# ---- Frontend ----
# Used internally only — frontend calls go through nginx on port 80
FRONTEND_URL=http://localhost

# ---- PostgREST ----
PGRST_DB_URI=postgresql://rapidbase:change_me_in_production_32chars@postgres:5432/rapidbase
PGRST_DB_ANON_ROLE=web_anon
PGRST_DB_SCHEMAS=public

# ============================================================
# GitHub Actions CI/CD — Repository Secrets
# These are NOT used at runtime. Configure them in:
#   GitHub → Repository → Settings → Secrets and variables → Actions
# ============================================================

# ---- Docker Hub (image push) ----
# DOCKERHUB_USERNAME=your_dockerhub_username
# DOCKERHUB_TOKEN=your_dockerhub_access_token

# ---- Email Alerts (CI failure/success notifications) ----
# MAIL_USERNAME=your_gmail_address@gmail.com
# MAIL_PASSWORD=your_gmail_app_password        # Use Gmail App Password, NOT your account password
# ALERT_EMAIL_ADDRESS=alerts_recipient@example.com

# ============================================================
# Terraform / AWS Infrastructure
# Set these as environment variables or in terraform.tfvars
# NEVER commit real AWS credentials!
# ============================================================

# AWS credentials (used by Terraform — set via env or aws configure)
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_DEFAULT_REGION=ap-south-1

# Terraform variable overrides (optional — defaults are set in variable.tf)
# TF_VAR_ami_id=ami-03446a3af42c5e74e
# TF_VAR_instance_type=m7i-flex.large
# TF_VAR_root_storage=30
